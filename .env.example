# GA4 Measurement ID (client-side, safe to expose)
# Leave empty to disable analytics (consent banner still shows)
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Notion integration token — keep secret
# https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxx

# Notion Leads database ID (from the DB URL)
NOTION_LEADS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email address for form notification mails
CONTACT_MAIL_TO=info@swisslyit.ch

# (Optional) Comma-separated trusted reverse-proxy IPs (REMOTE_ADDR values).
# Empty ⇒ X-Forwarded-For is ignored and REMOTE_ADDR is used (safe default,
# prevents rate-limit bypass via forged XFF). Only set behind a known proxy/CDN.
TRUSTED_PROXY=
