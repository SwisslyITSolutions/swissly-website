# ─── Swissly IT Solutions — Apache .htaccess ─────────────────────────────────
# Hostpoint shared hosting (Apache 2.4, mod_rewrite, mod_headers, mod_expires)

Options -Indexes
DirectoryIndex index.html

# ──────────────────────────────────────────────────────────────────────────────
# 1. REWRITES: HTTPS · www→apex · trailing-slash normalisation
# ──────────────────────────────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1a. Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # 1b. www → apex (https://www.swisslyit.ch → https://swisslyit.ch)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

  # 1c. Add trailing slash to directories (matches Astro trailingSlash:'always')
  #     Skip: existing files, paths with extensions, already-slash-terminated
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !\.\w{2,6}$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.+)$ $1/ [L,R=301]
</IfModule>

# ──────────────────────────────────────────────────────────────────────────────
# 2. CACHE CONTROL
# ──────────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # NOTE: <Location>/<LocationMatch> are NOT permitted in .htaccess (Apache returns
  # 500). Cache rules are therefore expressed by file extension via <FilesMatch>,
  # which IS allowed in .htaccess and covers the hashed _astro/ + vendor/ + image assets.

  # Hashed / immutable build assets (Astro bundles, vendored JS/CSS, fonts) — 1 year
  <FilesMatch "\.(js|mjs|css|woff2|woff|ttf|otf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Images — 30 days
  <FilesMatch "\.(svg|webp|avif|png|jpg|jpeg|gif|ico)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>

  # HTML pages — no cache (always re-validate)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ──────────────────────────────────────────────────────────────────────────────
# 3. COMPRESSION
# ──────────────────────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml font/woff2
</IfModule>

# ──────────────────────────────────────────────────────────────────────────────
# 4. SECURITY HEADERS
# ──────────────────────────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  # Prevent MIME-type sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Control referrer information
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Restrict browser features
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"

  # Clickjacking protection (legacy browsers; CSP frame-ancestors covers modern)
  Header always set X-Frame-Options "DENY"

  # Content Security Policy
  # Notes:
  #   - script-src 'unsafe-inline': Astro inlines module scripts + consent setup
  #   - style-src 'unsafe-inline': Astro inlines component-scoped styles
  #   - googletagmanager.com: GA4 consent-gated loader
  #   - google-analytics.com / analytics.google.com: GA4 data endpoints
  #   - openstreetmap.org: OSM tile images for Leaflet map
  #   - frame-ancestors 'none': prevent page from being embedded in iframes
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://*.openstreetmap.org https://www.google-analytics.com; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://www.googletagmanager.com https://region1.google-analytics.com https://region1.analytics.google.com; font-src 'self'; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'"

  # HSTS — enable after confirming HTTPS works on Hostpoint (start with low max-age)
  # Header always set Strict-Transport-Security "max-age=86400; includeSubDomains"
  # TODO: After 30-day test period, raise to: max-age=31536000; includeSubDomains; preload
</IfModule>

# ──────────────────────────────────────────────────────────────────────────────
# 5. ERROR PAGES
# ──────────────────────────────────────────────────────────────────────────────
ErrorDocument 404 /404.html
