---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title = "Swissly IT Solutions",
  description = "Webdesign aus Ebikon · Webseiten und Webshops für Schweizer KMU",
  noindex = false,
  ogImage,
} = Astro.props;

const robots = noindex ? "noindex, nofollow" : "index, follow";
const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site ?? "https://swisslyit.ch",
).toString();
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site ?? "https://swisslyit.ch").toString()
  : undefined;
---

<!doctype html>
<html lang="de-CH">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-swissly-gold focus:text-swissly-navy focus:px-4 focus:py-2 focus:rounded focus:font-body focus:font-medium"
    >
      Zum Inhalt springen
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
