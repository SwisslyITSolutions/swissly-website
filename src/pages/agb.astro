---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import Section from '../components/ui/Section.astro';
import { agbData } from '../data/legal';
---

<BaseLayout
  title="AGB — Swissly IT Solutions"
  description="Allgemeine Geschäftsbedingungen der Swissly IT Solutions KLG."
  path="/agb/"
>
  <PageHero
    eyebrow="rechtliches"
    title="Allgemeine Geschäftsbedingungen"
    intro="Gültig für alle Leistungen der Swissly IT Solutions KLG."
  />

  <Section tone="light">
    <div class="mx-auto max-w-3xl">
      <div class="flex flex-col gap-10 text-ink/80">
        {
          agbData.sections.map((section) => (
            <div>
              <h2 class="font-display text-xl font-bold text-ink">{section.heading}</h2>
              <p class="mt-3 text-sm leading-relaxed text-ink/70">{section.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>
</BaseLayout>
