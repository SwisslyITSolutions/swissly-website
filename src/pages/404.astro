---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import Section from '../components/ui/Section.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout
  title="Seite nicht gefunden — Swissly IT Solutions"
  description="Diese Seite existiert nicht. Finden Sie den Weg zurück zu Swissly IT Solutions."
  path="/404/"
  noindex={true}
>
  <PageHero
    eyebrow="404"
    title="Diese Seite gibt es nicht (mehr)."
    intro="Kein Grund zur Panik — wir finden gemeinsam, was Sie suchen."
  />

  <Section tone="dark">
    <div class="mx-auto max-w-2xl">
      <p class="mb-10 text-center font-mono text-sm text-white/50">
        Webseiten, die einfach laufen. Diese hier auch — nur nicht auf dieser URL.
      </p>

      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <Button href="/" label="Zur Startseite" variant="primary" />
        <Button href="/leistungen/" label="Unsere Leistungen" variant="outline" />
        <Button href="/kontakt/" label="Kontakt aufnehmen" variant="outline" />
      </div>
    </div>
  </Section>
</BaseLayout>
