---
import BaseLayout from '../layouts/BaseLayout.astro';
import FormField from '../components/ui/FormField.astro';

interface ThemaOption {
    value: string;
    label: string;
}

const themaOptions: ThemaOption[] = [
    { value: 'webseite', label: 'Neue Webseite' },
    { value: 'redesign', label: 'Redesign / Migration' },
    { value: 'webshop', label: 'Webshop' },
    { value: 'wartung', label: 'Wartung & Support' },
    { value: 'seo', label: 'SEO & Performance' },
    { value: 'sonstiges', label: 'Sonstiges' },
];

const contactEndpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? '';
---
<BaseLayout
    title="Kontakt – Swissly IT Solutions"
    description="Sprechen wir über Ihr Projekt. Schicken Sie uns eine Nachricht und wir melden uns innerhalb eines Werktags."
>
    <section class="bg-swissly-navy">
        <div class="max-w-4xl mx-auto px-6 py-20 md:py-28">
            <p class="font-mono text-sm text-swissly-gold mb-6 tracking-wide">// Kontakt</p>

            <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-bold text-swissly-offwhite leading-tight mb-6">
                Sprechen wir über Ihr Projekt.
            </h1>

            <p class="font-body text-lg text-swissly-offwhite/80 leading-relaxed max-w-3xl">
                Schicken Sie uns eine Nachricht über das Formular. Wir melden uns innerhalb eines Werktags bei Ihnen zurück und schlagen einen Termin für ein 30-minütiges Erstgespräch vor – kostenlos, unverbindlich und ohne Verkaufsgespräch.
            </p>
        </div>
    </section>

    <section class="bg-swissly-offwhite">
        <div class="max-w-2xl mx-auto px-6 py-20 md:py-28">
            <form
                id="kontakt-form"
                method="POST"
                action={contactEndpoint || '#'}
                data-endpoint={contactEndpoint}
                class="space-y-6"
                novalidate
            >
                <FormField
                    type="text"
                    name="name"
                    label="Name *"
                    placeholder="Ihr Vor- und Nachname"
                    autocomplete="name"
                    required
                />

                <FormField
                    type="text"
                    name="firma"
                    label="Firma"
                    hint="(optional)"
                    placeholder="Falls Sie für ein Unternehmen anfragen"
                    autocomplete="organization"
                />

                <FormField
                    type="email"
                    name="email"
                    label="E-Mail *"
                    placeholder="ihre.adresse@beispiel.ch"
                    autocomplete="email"
                    required
                />

                <FormField
                    type="tel"
                    name="telefon"
                    label="Telefon (optional)"
                    placeholder="Falls Ihnen ein Anruf lieber ist"
                    autocomplete="tel"
                />

                <fieldset>
                    <legend class="block font-body text-sm font-medium text-swissly-text mb-2">
                        Worum geht es? *
                    </legend>
                    <span class="block font-body text-xs text-swissly-text/85 mb-3 italic">
                        Mehrfachauswahl möglich
                    </span>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                        {themaOptions.map((option) => (
                            <label
                                for={`thema-${option.value}`}
                                class="flex items-center gap-3 cursor-pointer p-3 border border-swissly-divider rounded hover:border-swissly-gold transition-colors"
                            >
                                <input
                                    type="checkbox"
                                    name="thema"
                                    id={`thema-${option.value}`}
                                    value={option.value}
                                    class="w-4 h-4 accent-swissly-gold"
                                />
                                <span class="font-body text-sm text-swissly-text">{option.label}</span>
                            </label>
                        ))}
                    </div>
                </fieldset>

                <div>
                    <label for="nachricht" class="block font-body text-sm font-medium text-swissly-text mb-2">
                        Nachricht *
                    </label>
                    <textarea
                        name="nachricht"
                        id="nachricht"
                        rows="6"
                        required
                        placeholder="Beschreiben Sie kurz, was Sie vorhaben – ein paar Sätze reichen"
                        class="block w-full px-4 py-3 bg-white border border-swissly-divider rounded font-body text-base text-swissly-text focus:outline-none focus:border-swissly-gold focus:ring-1 focus:ring-swissly-gold transition-colors resize-y"
                    ></textarea>
                </div>

                <div class="hidden" aria-hidden="true">
                    <label for="website">Website (Bitte leer lassen)</label>
                    <input type="text" name="website" id="website" tabindex="-1" />
                </div>

                <div class="pt-2">
                    <p class="font-body text-sm text-swissly-text/85 leading-relaxed">
                        Mit dem Absenden stimmen Sie zu, dass wir Ihre Angaben zur Bearbeitung Ihrer Anfrage verwenden. Details in unserer <a href="/datenschutz" class="text-swissly-gold-dark underline">Datenschutzerklärung</a>.
                    </p>
                </div>

                <div
                    id="form-status"
                    role="status"
                    aria-live="polite"
                    class="hidden font-body text-sm rounded-lg px-4 py-3 border"
                ></div>

                <div class="pt-4">
                    <button
                        type="submit"
                        id="form-submit"
                        class="bg-swissly-navy text-swissly-offwhite font-body font-medium px-8 py-4 rounded hover:bg-swissly-navy/90 transition inline-flex items-center gap-2 cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed"
                    >
                        <span data-label-default>Anfrage senden</span>
                        <span data-label-loading class="hidden">Wird gesendet…</span>
                    </button>
                </div>
            </form>

            <script>
                const form = document.getElementById('kontakt-form') as HTMLFormElement | null;
                const status = document.getElementById('form-status') as HTMLDivElement | null;
                const submit = document.getElementById('form-submit') as HTMLButtonElement | null;
                const labelDefault = submit?.querySelector<HTMLSpanElement>('[data-label-default]');
                const labelLoading = submit?.querySelector<HTMLSpanElement>('[data-label-loading]');

                function showStatus(kind: 'success' | 'error' | 'info', message: string): void {
                    if (!status) return;
                    status.textContent = message;
                    status.className = 'font-body text-sm rounded-lg px-4 py-3 border';
                    if (kind === 'success') {
                        status.classList.add('bg-green-50', 'border-green-200', 'text-green-900');
                    } else if (kind === 'error') {
                        status.classList.add('bg-red-50', 'border-red-200', 'text-red-900');
                    } else {
                        status.classList.add('bg-amber-50', 'border-amber-200', 'text-amber-900');
                    }
                    status.classList.remove('hidden');
                }

                function setLoading(loading: boolean): void {
                    if (!submit || !labelDefault || !labelLoading) return;
                    submit.disabled = loading;
                    labelDefault.classList.toggle('hidden', loading);
                    labelLoading.classList.toggle('hidden', !loading);
                }

                form?.addEventListener('submit', async (event) => {
                    const endpoint = form.dataset.endpoint;
                    if (!endpoint) {
                        event.preventDefault();
                        showStatus(
                            'info',
                            'Das Kontaktformular ist noch nicht verbunden. Bitte schreiben Sie uns direkt an info@swisslyit.ch.',
                        );
                        return;
                    }

                    event.preventDefault();
                    setLoading(true);

                    const data = new FormData(form);
                    const payload = {
                        name: String(data.get('name') ?? ''),
                        firma: String(data.get('firma') ?? ''),
                        email: String(data.get('email') ?? ''),
                        telefon: String(data.get('telefon') ?? ''),
                        thema: data.getAll('thema').map((v) => String(v)),
                        nachricht: String(data.get('nachricht') ?? ''),
                        website: String(data.get('website') ?? ''),
                    };

                    try {
                        const response = await fetch(endpoint, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload),
                        });
                        const json = (await response.json()) as { ok: boolean; error?: string };
                        if (response.ok && json.ok) {
                            window.location.href = '/kontakt/danke';
                            return;
                        }
                        showStatus(
                            'error',
                            json.error ?? 'Etwas ist schiefgegangen. Bitte direkt an info@swisslyit.ch senden.',
                        );
                    } catch {
                        showStatus(
                            'error',
                            'Verbindungsfehler. Bitte E-Mail an info@swisslyit.ch senden.',
                        );
                    } finally {
                        setLoading(false);
                    }
                });
            </script>
        </div>
    </section>

    <section class="bg-swissly-navy">
        <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
            <p class="font-mono text-sm text-swissly-gold mb-4 tracking-wide">// Standort</p>

            <h2 class="font-headline text-3xl md:text-4xl font-bold text-swissly-offwhite leading-tight mb-12">
                Mit Sitz in Ebikon.
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-5 gap-12">
                <div class="md:col-span-3">
                    <div class="relative w-full h-[400px] md:h-[500px] rounded-lg overflow-hidden border border-swissly-offwhite/10">
                        <div id="map" class="w-full h-full"></div>
                    </div>
                </div>

                <div class="md:col-span-2 flex flex-col gap-8">
                    <div>
                        <p class="font-mono text-xs text-swissly-gold mb-2 tracking-wide">// E-Mail</p>
                        <a
                            href="mailto:info@swisslyit.ch"
                            class="font-headline text-xl font-bold text-swissly-offwhite hover:text-swissly-gold transition-colors"
                        >
                            info@swisslyit.ch
                        </a>
                    </div>

                    <div>
                        <p class="font-mono text-xs text-swissly-gold mb-2 tracking-wide">// Standort</p>
                        <p class="font-headline text-xl font-bold text-swissly-offwhite">
                            Ebikon, Luzern
                        </p>
                        <p class="font-body text-sm text-swissly-offwhite/70 leading-relaxed mt-3">
                            Wir arbeiten ortsunabhängig und betreuen Kundinnen und Kunden in der gesamten Deutschschweiz. Persönliche Treffen vor Ort organisieren wir gerne, wenn Sie sie wünschen.
                        </p>
                    </div>

                    <div>
                        <p class="font-mono text-xs text-swissly-gold mb-2 tracking-wide">// Antwortzeit</p>
                        <p class="font-headline text-xl font-bold text-swissly-offwhite">
                            Innerhalb 24 Stunden
                        </p>
                        <p class="font-body text-sm text-swissly-offwhite/70 leading-relaxed mt-3">
                            An Werktagen melden wir uns spätestens am nächsten Tag. Bei dringenden Anliegen erwähnen Sie das bitte in Ihrer Nachricht.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />
    <script is:inline src="/vendor/leaflet/leaflet.js"></script>
    <script is:inline>
        window.addEventListener('DOMContentLoaded', () => {
            const mapElement = document.getElementById('map');
            if (!mapElement || typeof L === 'undefined') return;

            L.Icon.Default.imagePath = '/vendor/leaflet/images/';

            const ebikon = [47.0817, 8.3458];
            const map = L.map('map').setView(ebikon, 13);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                maxZoom: 19,
            }).addTo(map);

            L.marker(ebikon)
                .addTo(map)
                .bindPopup('Swissly IT Solutions · 6030 Ebikon');
        });
    </script>
</BaseLayout>
