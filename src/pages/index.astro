---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Swissly IT Solutions – Webdesign aus Ebikon">
    <main class="min-h-screen flex items-center justify-center bg-gradient-to-br from-slate-900 to-slate-700 text-white">
        <div class="text-center px-4">
            <h1 class="text-5xl md:text-7xl font-bold mb-4">Swissly IT Solutions</h1>
            <p class="text-xl md:text-2xl text-slate-300 mb-8">Webdesign aus Ebikon · Webseiten und Webshops für Schweizer KMU</p>
            <div class="inline-block px-6 py-3 bg-red-600 hover:bg-red-700 transition rounded-lg font-semibold cursor-pointer">
                Coming Soon
            </div>
        </div>
    </main>
</Layout>
