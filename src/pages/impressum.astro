---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import Section from '../components/ui/Section.astro';
import { impressumData } from '../data/legal';
import { site } from '../data/site';
---

<BaseLayout
  title="Impressum — Swissly IT Solutions"
  description="Impressum und rechtliche Angaben der Swissly IT Solutions KLG."
  path="/impressum/"
>
  <PageHero
    eyebrow="rechtliches"
    title="Impressum"
    intro="Transparenz und Vertrauen sind die Basis unserer Arbeit."
  />

  <Section tone="light">
    <div class="mx-auto max-w-3xl">
      <div class="prose prose-sm max-w-none text-ink/80">
        <!-- Verantwortlich -->
        <h2 class="font-display text-xl font-bold text-ink">Verantwortlich für den Inhalt</h2>
        <p class="mt-3 text-sm leading-relaxed">
          {site.legalName}<br />
          Georg Ristic &amp; Taha Afif<br />
          {site.address.street}<br />
          {site.address.zip} {site.address.city}<br />
          Schweiz
        </p>

        <!-- Kontakt -->
        <h2 class="mt-10 font-display text-xl font-bold text-ink">Kontakt</h2>
        <p class="mt-3 text-sm leading-relaxed">
          E-Mail: <a href={`mailto:${site.email}`} class="underline">{site.email}</a><br />
          Website: <a href="https://www.swisslyit.ch" class="underline">www.swisslyit.ch</a>
        </p>

        <!-- Rechtsform -->
        <h2 class="mt-10 font-display text-xl font-bold text-ink">Rechtsform</h2>
        <p class="mt-3 text-sm leading-relaxed">Kollektivgesellschaft (KLG) nach Schweizer Recht</p>

        <!-- Handelsregister -->
        <h2 class="mt-10 font-display text-xl font-bold text-ink">Handelsregister</h2>
        <p class="mt-3 text-sm leading-relaxed">{site.commercialRegister}</p>

        <!-- MWST -->
        <h2 class="mt-10 font-display text-xl font-bold text-ink">Mehrwertsteuer</h2>
        <p class="mt-3 text-sm leading-relaxed">{site.vat}</p>

        <!-- Legal sections from data -->
        {
          impressumData.sections
            .filter((s) => !['Verantwortlich für den Inhalt', 'Kontakt', 'Rechtsform', 'Handelsregister', 'Mehrwertsteuer'].includes(s.heading))
            .map((section) => (
              <div class="mt-10">
                <h2 class="font-display text-xl font-bold text-ink">{section.heading}</h2>
                <p class="mt-3 whitespace-pre-line text-sm leading-relaxed text-ink/70">
                  {section.body}
                </p>
              </div>
            ))
        }
      </div>
    </div>
  </Section>
</BaseLayout>
