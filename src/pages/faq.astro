---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import Section from '../components/ui/Section.astro';
import Accordion from '../components/ui/Accordion.astro';
import CtaBlock from '../components/sections/CtaBlock.astro';
import { faq } from '../data/faq';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  })),
};
---

<BaseLayout
  title="FAQ: Häufige Fragen | Swissly IT Solutions"
  description="Ehrliche Antworten auf die wichtigsten Fragen rund um Webdesign, IT-Support und Care-Pläne von Swissly IT Solutions."
  path="/faq/"
  jsonLd={faqSchema}
>
  <PageHero
    eyebrow="faq"
    title="Häufige Fragen"
    intro="Ehrliche Antworten auf die wichtigsten Fragen rund um Webdesign, IT-Support und Care-Pläne."
  />

  <Section tone="light">
    <div class="mx-auto max-w-3xl">
      <Accordion items={faq} />
    </div>
  </Section>

  <CtaBlock />
</BaseLayout>
