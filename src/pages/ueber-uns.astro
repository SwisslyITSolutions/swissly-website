---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import Section from '../components/ui/Section.astro';
import EcsTeaser from '../components/sections/EcsTeaser.astro';
import CtaBlock from '../components/sections/CtaBlock.astro';
import { site } from '../data/site';
import { team } from '../data/team';
---

<BaseLayout
  title="Über uns — Swissly IT Solutions"
  description="Erfahren Sie mehr über das Team hinter Swissly IT Solutions."
  path="/ueber-uns/"
>
  <PageHero
    eyebrow="über uns"
    title="IT-Partner, dem Sie vertrauen können."
    intro="Wir sind Taha und Georg — ein Zweier-Team aus Ebikon, Luzern, das IT-Dienstleistungen so anbietet, wie wir sie selbst gerne hätten: ehrlich, verständlich und auf Augenhöhe."
  />

  <!-- Story -->
  <Section tone="dark">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-display text-2xl font-bold tracking-tight text-white md:text-3xl">
        Warum Swissly?
      </h2>
      <div class="mt-6 space-y-5 text-base leading-relaxed text-white/70">
        <p>
          Swissly IT Solutions wurde gegründet, weil wir gesehen haben, wie oft KMU mit
          IT-Lösungen kämpfen, die zu teuer, zu kompliziert oder einfach nicht passend
          für ihren Betriebsalltag sind. Wir wollten das ändern.
        </p>
        <p>
          Unser Versprechen: keine versteckten Kosten, kein Fachjargon, keine
          überdimensionierten Systeme. Nur ehrliche Arbeit — angepasst an das, was Sie
          wirklich brauchen.
        </p>
        <p>
          Als Kollektivgesellschaft mit Sitz in Ebikon, Luzern, sind wir nah bei unseren
          Kundinnen und Kunden — persönlich vor Ort in der Zentralschweiz oder schnell
          remote erreichbar.
        </p>
      </div>
    </div>
  </Section>

  <!-- Values -->
  <Section tone="light">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-display text-2xl font-bold tracking-tight text-ink md:text-3xl">
        Unsere Werte
      </h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          site.values.map((value) => (
            <div class="rounded-xl border border-ink/10 bg-white p-6 shadow-sm">
              <h3 class="font-display text-lg font-bold text-ink">{value.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink/70">{value.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <!-- Team -->
  <Section tone="dark">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-display text-2xl font-bold tracking-tight text-white md:text-3xl">
        Das Team
      </h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          team.map((member) => (
            <div class="rounded-xl border border-white/10 bg-navy-800 p-6">
              <h3 class="font-display text-xl font-bold text-white">{member.name}</h3>
              <p class="mt-1 font-mono text-xs font-medium uppercase tracking-wider text-gold-bright">
                {member.role}
              </p>
              <p class="mt-4 text-sm leading-relaxed text-white/70">{member.bio}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <EcsTeaser />
  <CtaBlock />
</BaseLayout>
