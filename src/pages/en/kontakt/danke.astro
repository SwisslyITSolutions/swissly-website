---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Eyebrow from '../../../components/ui/Eyebrow.astro';
import Button from '../../../components/ui/Button.astro';
---

<BaseLayout
  title="Thank you | Swissly IT Solutions"
  description="Thank you for your message. We will be in touch soon."
  path="/en/kontakt/danke/"
  lang="en"
  noindex={true}
>
  <section class="relative overflow-hidden bg-navy-900">
    <div class="dot-grid pointer-events-none absolute inset-0 opacity-[0.4]" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-80 w-80 -translate-x-1/2 rounded-full bg-gold/10 blur-[120px]"
      aria-hidden="true"
    >
    </div>
    <div class="container-x relative flex min-h-[70vh] flex-col items-center justify-center py-20 text-center">
      <Eyebrow>message sent</Eyebrow>
      <h1 class="mt-5 font-display text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Thank you!
      </h1>
      <p class="mt-5 max-w-xl text-lg text-surface-text/80">
        We have received your message and will get back to you within 24 hours, on working days.
      </p>
      <p class="mt-2 max-w-xl text-surface-text/60">
        In the meantime, feel free to look around our website.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <Button href="/en/" label="Back to homepage" variant="primary" />
        <Button href="/en/leistungen/" label="Our services" variant="outline" />
      </div>
    </div>
  </section>
</BaseLayout>
