---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Section from '../../components/ui/Section.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout
  title="Page not found | Swissly IT Solutions"
  description="This page does not exist. Find your way back to Swissly IT Solutions."
  path="/en/404/"
  lang="en"
  noindex={true}
>
  <PageHero
    eyebrow="404"
    title="This page does not exist (any more)."
    intro="No need to panic, we will find what you are looking for together."
  />

  <Section tone="dark">
    <div class="mx-auto max-w-2xl">
      <p class="mb-10 text-center font-mono text-sm text-white/50">
        Websites that just work. This one too, just not at this URL.
      </p>

      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <Button href="/en/" label="To the homepage" variant="primary" />
        <Button href="/en/leistungen/" label="Our services" variant="outline" />
        <Button href="/en/kontakt/" label="Get in touch" variant="outline" />
      </div>
    </div>
  </Section>
</BaseLayout>
