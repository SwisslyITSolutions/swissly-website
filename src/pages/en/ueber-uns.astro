---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/sections/PageHero.astro';
import Section from '../../components/ui/Section.astro';
import EcsTeaser from '../../components/sections/EcsTeaser.astro';
import CtaBlock from '../../components/sections/CtaBlock.astro';
import { getContent } from '../../i18n/content';
import tahaPhoto from '../../assets/team/taha.jpg';
import georgPhoto from '../../assets/team/georg.jpg';

const { team, values } = getContent('en');

// Map each team member to their portrait. Astro optimizes/resizes these at build.
const photos: Record<string, ImageMetadata> = {
  'Taha Afif': tahaPhoto,
  'Georg Ristic': georgPhoto,
};
---

<BaseLayout
  title="About | Swissly IT Solutions"
  description="Learn more about the team behind Swissly IT Solutions."
  path="/en/ueber-uns/"
  lang="en"
>
  <PageHero
    eyebrow="about"
    title="An IT partner you can trust."
    intro="We are Taha and Georg, a two-person team from Ebikon, Lucerne. We offer IT services the way we would want them ourselves: honest, clear, and on equal terms."
  />

  <!-- Story -->
  <Section tone="dark">
    <div class="mx-auto max-w-3xl">
      <h2 class="font-display text-2xl font-bold tracking-tight text-white md:text-3xl">
        Why Swissly?
      </h2>
      <div class="mt-6 space-y-5 text-base leading-relaxed text-white/70">
        <p>
          Swissly IT Solutions was founded because too many SMEs struggle with IT
          solutions that are too expensive, too complicated, or simply not made for
          their day-to-day business. We wanted to change that.
        </p>
        <p>
          Our promise: no hidden costs, no jargon, no oversized systems. Just honest
          work, tailored to what you really need.
        </p>
        <p>
          As a general partnership based in Ebikon, Lucerne, we stay close to our
          clients: personally on site in Central Switzerland or quickly reachable
          remotely.
        </p>
      </div>
    </div>
  </Section>

  <!-- Values -->
  <Section tone="light">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-display text-2xl font-bold tracking-tight text-ink md:text-3xl">
        Our values
      </h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {
          values.map((value) => (
            <div class="rounded-xl border border-ink/10 bg-white p-6 shadow-sm">
              <h3 class="font-display text-lg font-bold text-ink">{value.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink/70">{value.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <!-- Team -->
  <Section tone="dark">
    <div class="mx-auto max-w-5xl">
      <h2 class="font-display text-2xl font-bold tracking-tight text-white md:text-3xl">
        The team
      </h2>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {
          team.map((member) => (
            <div class="rounded-xl border border-white/10 bg-navy-800 p-6">
              {photos[member.name] && (
                <Image
                  src={photos[member.name]}
                  alt={`${member.name}, ${member.role} at Swissly IT Solutions`}
                  width={640}
                  format="webp"
                  class={`mb-5 aspect-[4/5] w-full rounded-xl border border-white/10 object-cover ${member.name === 'Taha Afif' ? 'object-bottom' : 'object-top'}`}
                />
              )}
              <h3 class="font-display text-xl font-bold text-white">{member.name}</h3>
              <p class="mt-1 font-mono text-xs font-medium uppercase tracking-wider text-gold-bright">
                {member.role}
              </p>
              <p class="mt-4 text-sm leading-relaxed text-white/70">{member.bio}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <EcsTeaser lang="en" />
  <CtaBlock lang="en" />
</BaseLayout>
