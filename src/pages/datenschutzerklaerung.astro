---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import Section from '../components/ui/Section.astro';
import { datenschutzData } from '../data/legal';
---

<BaseLayout
  title="Datenschutzerklärung — Swissly IT Solutions"
  description="Datenschutzerklärung der Swissly IT Solutions KLG. Transparenz und Sicherheit für Ihre Daten."
  path="/datenschutzerklaerung/"
>
  <PageHero
    eyebrow="datenschutz"
    title="Datenschutzerklärung"
    intro="Transparenz und Sicherheit für Ihre Daten."
  />

  <Section tone="light">
    <div class="mx-auto max-w-3xl">
      <div class="flex flex-col gap-10 text-ink/80">
        {
          datenschutzData.sections.map((section) => (
            <div>
              <h2 class="font-display text-xl font-bold text-ink">{section.heading}</h2>
              <p class="mt-3 text-sm leading-relaxed text-ink/70">{section.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>
</BaseLayout>
