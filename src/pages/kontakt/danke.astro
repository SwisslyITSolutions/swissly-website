---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import Button from '../../components/ui/Button.astro';
---

<BaseLayout
  title="Danke | Swissly IT Solutions"
  description="Vielen Dank für Ihre Nachricht. Wir melden uns bald."
  path="/kontakt/danke/"
  noindex={true}
>
  <section class="relative overflow-hidden bg-navy-900">
    <div class="dot-grid pointer-events-none absolute inset-0 opacity-[0.4]" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute left-1/2 top-0 h-80 w-80 -translate-x-1/2 rounded-full bg-gold/10 blur-[120px]"
      aria-hidden="true"
    >
    </div>
    <div class="container-x relative flex min-h-[70vh] flex-col items-center justify-center py-20 text-center">
      <Eyebrow>nachricht gesendet</Eyebrow>
      <h1 class="mt-5 font-display text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Vielen Dank!
      </h1>
      <p class="mt-5 max-w-xl text-lg text-surface-text/80">
        Wir haben Ihre Nachricht erhalten und melden uns innerhalb von 24 Stunden, werktags.
      </p>
      <p class="mt-2 max-w-xl text-surface-text/60">
        In der Zwischenzeit können Sie sich gerne auf unserer Website umsehen.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <Button href="/" label="Zurück zur Startseite" variant="primary" />
        <Button href="/leistungen/" label="Unsere Leistungen" variant="outline" />
      </div>
    </div>
  </section>
</BaseLayout>
