---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ServiceCard from '../../components/ui/ServiceCard.astro';

interface Service {
    title: string;
    description: string;
    href: string;
    class?: string;
}

interface Principle {
    title: string;
    description: string;
}

const services: Service[] = [
    {
        title: 'Webseiten & Redesign',
        description:
            'Neue Webseite oder ein Refresh für Ihren bestehenden Auftritt. Wir entwickeln moderne, schnelle Seiten – mit oder ohne CMS, je nachdem, was Sie tatsächlich pflegen wollen.',
        href: '/leistungen/webseiten',
        class: 'md:col-span-2 lg:col-span-2',
    },
    {
        title: 'Webshops',
        description:
            'Online verkaufen, ohne in einem unübersichtlichen System zu versinken. Wir setzen Webshops auf, die im Backend wie im Kaufprozess einfach funktionieren.',
        href: '/leistungen/webshops',
        class: 'md:col-span-2 lg:col-span-2',
    },
    {
        title: 'Wartung & Support',
        description:
            'Eine Webseite ist kein Möbelstück, sie braucht Pflege. Wir kümmern uns um Updates, Sicherheit und kleinere Anpassungen – und sind erreichbar, wenn doch einmal etwas klemmt.',
        href: '/leistungen/wartung',
        class: 'md:col-span-2 lg:col-span-2',
    },
    {
        title: 'Migrationen',
        description:
            'Veraltete oder lahme Webseite? Wir bringen Ihren Auftritt auf einen modernen Tech-Stack – sauber migriert, ohne dass Inhalte oder Suchmaschinen-Rankings verloren gehen.',
        href: '/leistungen/migrationen',
        class: 'md:col-span-2 lg:col-start-2 lg:col-span-2',
    },
    {
        title: 'SEO-Optimierungen & Performance',
        description:
            'Schnelle Webseiten werden besser gefunden. Wir optimieren Ladezeiten und technisches SEO, damit Ihre Inhalte bei Google auffindbar bleiben – ohne Werbebudget-Diskussionen.',
        href: '/leistungen/seo-performance',
        class: 'md:col-start-2 md:col-span-2 lg:col-start-4 lg:col-span-2',
    },
];

const principles: Principle[] = [
    {
        title: 'Eine Sache, richtig.',
        description:
            'Wir konzentrieren uns auf Webentwicklung. Keine Allround-Agentur, die alles ein bisschen kann – sondern Spezialisten für das, was wir liefern.',
    },
    {
        title: 'Ehrliche Empfehlungen.',
        description:
            'Wenn ein WordPress-Refresh statt einem kompletten Neubau die bessere Lösung ist, sagen wir das. Wenn Sie eigentlich keinen Webshop brauchen, sagen wir das auch.',
    },
    {
        title: 'Schweizer Qualität, Schweizer Hosting.',
        description:
            'Hostpoint in der Schweiz, revDSG-konforme Verarbeitung, deutschsprachiger Support. Keine versteckten US-Abhängigkeiten in unserer Standard-Stack.',
    },
    {
        title: 'Sie bleiben Eigentümer.',
        description:
            'Code-Repository, Hosting-Account, Domain – alles auf Ihren Namen. Sie sind nicht an uns gebunden und können jederzeit wechseln.',
    },
];
---
<BaseLayout
    title="Leistungen – Swissly IT Solutions"
    description="Webseiten, Webshops, Wartung, Migrationen und SEO für KMU in der Deutschschweiz. Alles aus einer Hand, alles mit Schweizer Hosting."
>
    <section class="bg-swissly-navy">
        <div class="max-w-4xl mx-auto px-6 py-20 md:py-28">
            <p class="font-mono text-sm text-swissly-gold mb-6 tracking-wide">// Leistungen</p>

            <h1 class="font-headline text-4xl md:text-5xl lg:text-6xl font-bold text-swissly-offwhite leading-tight mb-6">
                Was wir für Sie bauen und pflegen.
            </h1>

            <p class="font-body text-lg text-swissly-offwhite/80 leading-relaxed mb-10 max-w-3xl">
                Unser Fokus liegt klar auf Webentwicklung. Vom ersten Konzept über den Bau bis zur laufenden Pflege betreuen wir alles aus einer Hand – für KMU in der Deutschschweiz.
            </p>

            <div class="flex flex-wrap gap-4">
                <a
                    href="/kontakt"
                    class="bg-swissly-gold text-swissly-navy font-body font-medium px-6 py-3 rounded hover:bg-swissly-gold/90 transition"
                >
                    Erstgespräch anfragen
                </a>
                <a
                    href="#leistungen"
                    class="text-swissly-offwhite font-body font-medium px-6 py-3 border border-swissly-offwhite/30 rounded hover:border-swissly-gold hover:text-swissly-gold transition"
                >
                    Leistungen ansehen
                </a>
            </div>
        </div>
    </section>

    <section id="leistungen" class="bg-swissly-offwhite">
        <div class="max-w-7xl mx-auto px-6 py-20 md:py-28">
            <p class="font-mono text-sm text-swissly-gold-dark mb-4 tracking-wide">// Übersicht</p>

            <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl font-bold text-swissly-navy leading-tight mb-6 max-w-3xl">
                Fünf Leistungen, die ineinandergreifen.
            </h2>

            <p class="font-body text-lg text-swissly-text leading-relaxed mb-16 max-w-3xl">
                Die meisten unserer Kundinnen und Kunden starten mit einer neuen Webseite oder einem Webshop und bleiben über die laufende Wartung mit uns in Kontakt. Sie können aber jede Leistung auch einzeln beziehen.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-6 gap-6">
                {services.map((service) => (
                    <ServiceCard
                        title={service.title}
                        description={service.description}
                        href={service.href}
                        class={service.class}
                    />
                ))}
            </div>
        </div>
    </section>

    <section class="bg-swissly-navy">
        <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
            <p class="font-mono text-sm text-swissly-gold mb-4 tracking-wide">// Wie wir arbeiten</p>

            <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl font-bold text-swissly-offwhite leading-tight mb-6 max-w-3xl">
                Vier Prinzipien, an denen Sie uns messen können.
            </h2>

            <p class="font-body text-lg text-swissly-offwhite/80 leading-relaxed mb-16 max-w-3xl">
                Egal welche Leistung – diese vier Punkte gelten für jeden Auftrag, den wir annehmen.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                {principles.map((principle) => (
                    <div>
                        <h3 class="font-headline text-xl font-bold text-swissly-offwhite mb-3 leading-tight">
                            {principle.title}
                        </h3>
                        <p class="font-body text-base text-swissly-offwhite/70 leading-relaxed">
                            {principle.description}
                        </p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section class="bg-swissly-offwhite">
        <div class="max-w-4xl mx-auto px-6 py-20 md:py-24 text-center">
            <h2 class="font-headline text-3xl md:text-4xl lg:text-5xl font-bold text-swissly-navy leading-tight mb-6">
                Nicht sicher, was Sie brauchen?
            </h2>

            <p class="font-body text-lg text-swissly-text leading-relaxed mb-10 max-w-2xl mx-auto">
                Im 30-minütigen Erstgespräch klären wir, welche Leistung zu Ihrem Anliegen passt – und ob es bei uns überhaupt richtig aufgehoben ist. Kostenlos, unverbindlich und ohne Verkaufsdruck.
            </p>

            <a
                href="/kontakt"
                class="inline-block bg-swissly-navy text-swissly-offwhite font-body font-medium px-8 py-4 rounded hover:bg-swissly-navy/90 transition text-base"
            >
                Erstgespräch anfragen
            </a>

            <p class="font-mono text-xs text-swissly-text/85 tracking-wide mt-8">
                // Antwort innerhalb 24 Stunden · Werktags
            </p>
        </div>
    </section>
</BaseLayout>
