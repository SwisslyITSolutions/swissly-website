---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Eyebrow from '../../components/ui/Eyebrow.astro';
import ServiceCard from '../../components/ui/ServiceCard.astro';
import PricingCard from '../../components/ui/PricingCard.astro';
import CarePlanCard from '../../components/ui/CarePlanCard.astro';
import CtaBlock from '../../components/sections/CtaBlock.astro';
import { services } from '../../data/services';
import { packages, pricingNote } from '../../data/pricing';
import { carePlans, carePlanNote } from '../../data/careplans';
import { site } from '../../data/site';

const origin = 'https://swisslyit.ch';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Start', item: `${origin}/` },
    { '@type': 'ListItem', position: 2, name: 'Leistungen', item: `${origin}/leistungen/` },
  ],
};
---

<BaseLayout
  title="Leistungen & Preise — Webseiten, IT & KI | Swissly IT"
  description="Alle Leistungen von Swissly IT auf einen Blick: Webseiten, Webshops, Wartung, Migrationen, SEO, IT-Support und KI-Schulungen. Transparente Festpreise ab CHF 1'490."
  path="/leistungen/"
  jsonLd={breadcrumb}
>
  <!-- Header -->
  <section class="relative overflow-hidden bg-navy-900">
    <div class="dot-grid pointer-events-none absolute inset-0 opacity-60" aria-hidden="true"></div>
    <div
      class="pointer-events-none absolute -top-40 right-1/4 h-[30rem] w-[30rem] rounded-full bg-gold/10 blur-[120px]"
      aria-hidden="true"
    >
    </div>
    <div class="container-x relative pb-16 pt-28 md:pb-20 md:pt-36">
      <div class="max-w-3xl">
        <Eyebrow>leistungen</Eyebrow>
        <h1
          class="mt-5 font-display font-extrabold tracking-tight text-white"
          style="font-size:clamp(2.25rem,5vw,3.5rem);line-height:1.05;letter-spacing:-0.02em"
        >
          Alles für Ihren digitalen Auftritt — aus einer Hand.
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-white/70">
          Von der Website über die laufende Pflege bis zu IT-Support und KI-Schulungen.
          Verständlich erklärt, in der Schweiz gehostet, mit Eigentum bei Ihnen.
        </p>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-navy-900 pb-20 md:pb-28">
    <div class="container-x">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((service) => (
            <ServiceCard
              title={service.title}
              teaser={service.teaser}
              href={`/leistungen/${service.slug}/`}
              eyebrow={service.eyebrow}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Website packages -->
  <section id="preise" class="border-t border-white/5 bg-navy-900 py-20 md:py-28">
    <div class="container-x">
      <div class="max-w-2xl">
        <Eyebrow>website-pakete</Eyebrow>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
          Transparente Festpreise.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-white/70">
          Drei Pakete für jeden Bedarf — vom kompakten One-Pager bis zum vollständigen
          Online-Shop. Klar kalkuliert, ohne versteckte Kosten.
        </p>
      </div>

      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        {
          packages.map((pkg) => (
            <PricingCard
              name={pkg.name}
              price={pkg.price}
              tagline={pkg.tagline}
              features={pkg.features}
              featured={pkg.featured}
              href={site.ctaHref}
            />
          ))
        }
      </div>

      <p class="mt-8 text-sm text-white/50">{pricingNote}</p>
    </div>
  </section>

  <!-- Care plans -->
  <section id="care" class="border-t border-white/5 bg-navy-800 py-20 md:py-28">
    <div class="container-x">
      <div class="max-w-2xl">
        <Eyebrow>care-pläne</Eyebrow>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
          Laufende Betreuung, monatlich kündbar.
        </h2>
        <p class="mt-5 text-lg leading-relaxed text-white/70">
          Updates, Backups, Monitoring und Support — wir halten Ihre Website sicher und
          aktuell, damit Sie sich um nichts kümmern müssen.
        </p>
      </div>

      <div class="mt-14 grid gap-6 lg:grid-cols-3">
        {
          carePlans.map((plan) => (
            <CarePlanCard
              name={plan.name}
              monthly={plan.monthly}
              features={plan.features}
              popular={plan.popular}
              href={site.ctaHref}
            />
          ))
        }
      </div>

      <p class="mt-8 text-sm text-white/50">{carePlanNote}</p>
    </div>
  </section>

  <!-- Hourly rate & modules -->
  <section class="bg-navy-900 py-16 md:py-20">
    <div class="container-x">
      <div
        class="grid gap-6 rounded-2xl border border-white/10 bg-navy-800/60 p-8 md:grid-cols-2 md:items-center md:p-10"
      >
        <div>
          <span class="font-mono text-xs font-medium tracking-wider text-gold-bright">
            <span aria-hidden="true">// </span>support &amp; einzelleistungen
          </span>
          <h2 class="mt-3 font-display text-2xl font-bold tracking-tight text-white">
            IT-Support im 15-Minuten-Takt.
          </h2>
          <p class="mt-3 text-sm leading-relaxed text-white/70">
            Persönlicher Support remote und vor Ort in der Zentralschweiz — fair
            abgerechnet, ohne Pauschalen. Einzelne Module bauen wir auf Anfrage genau
            nach Ihrem Bedarf.
          </p>
        </div>
        <div class="flex flex-col gap-4 sm:flex-row md:justify-end">
          <div class="rounded-xl border border-gold/30 bg-gold/10 px-6 py-5 text-center">
            <div class="flex items-baseline justify-center gap-1.5">
              <span class="font-mono text-sm text-gold-bright">CHF</span>
              <span class="font-display text-4xl font-extrabold tracking-tight text-white">
                {site.hourlyRate}
              </span>
            </div>
            <span class="mt-1 block font-mono text-xs text-white/60">pro Stunde</span>
          </div>
          <div class="rounded-xl border border-white/10 bg-navy-900/60 px-6 py-5 text-center">
            <span class="font-display text-2xl font-bold text-white">Module</span>
            <span class="mt-1 block font-mono text-xs text-white/60">auf Anfrage</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBlock title="Welche Leistung passt zu Ihnen?" />
</BaseLayout>
