---
import { services } from '../../data/services';
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';

// The four positioning pillars: Websites → Care → IT → Schulungen.
const pillarSlugs = ['webseiten', 'wartung-care', 'it-support', 'schulungen'];
const pillars = pillarSlugs
  .map((slug) => services.find((s) => s.slug === slug))
  .filter((s): s is NonNullable<typeof s> => Boolean(s));
---

<Section id="leistungen" tone="dark">
  <div class="max-w-2xl">
    <Eyebrow>was wir tun</Eyebrow>
    <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
      Vier Bereiche, ein Anspruch: dass es einfach läuft.
    </h2>
    <p class="mt-5 text-lg leading-relaxed text-white/70">
      Von der ersten Website über die laufende Pflege bis zum IT-Support und KI-Schulungen —
      alles aus einer Hand, in verständlicher Sprache.
    </p>
  </div>

  <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
    {
      pillars.map((pillar, i) => (
        <a
          href={`/leistungen/${pillar.slug}/`}
          class="group relative flex flex-col rounded-xl border border-white/10 bg-navy-800 p-6 transition duration-200 hover:-translate-y-0.5 hover:border-gold/40 hover:shadow-[0_0_30px_-10px_rgba(201,169,106,0.55)]"
        >
          <span class="font-mono text-xs text-gold-bright/50">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="mt-3 font-display text-lg font-bold tracking-tight text-white">
            {pillar.title}
          </h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-white/70">{pillar.teaser}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 font-mono text-xs text-gold-bright">
            Mehr erfahren
            <span aria-hidden="true" class="transition-transform duration-200 group-hover:translate-x-1">
              →
            </span>
          </span>
        </a>
      ))
    }
  </div>

  <div class="mt-10">
    <a
      href="/leistungen/"
      class="inline-flex items-center gap-2 font-mono text-sm text-white/70 transition hover:text-gold-bright"
    >
      Alle Leistungen ansehen
      <span aria-hidden="true">→</span>
    </a>
  </div>
</Section>
