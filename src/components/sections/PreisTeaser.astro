---
import Button from '../ui/Button.astro';
import { getLang, localizedPath, type Lang } from '../../i18n/utils';
import { getContent } from '../../i18n/content';

interface Props {
  lang?: Lang;
}
const { lang = getLang(Astro) } = Astro.props;
const { packages } = getContent(lang);
const leistungenHref = localizedPath(lang, '/leistungen/');

const copy = {
  de: {
    eyebrow: 'transparente preise',
    heading: 'Festpreise statt Überraschungen.',
    intro:
      'Klare Pakete vom One-Pager bis zum Online-Shop, netto und ohne versteckte Kosten. Laufende Betreuung ab CHF 59/Monat.',
    cta: 'Alle Preise & Leistungen',
  },
  en: {
    eyebrow: 'transparent pricing',
    heading: 'Fixed prices, no surprises.',
    intro:
      'Clear packages from a one-pager to an online shop, net and with no hidden costs. Ongoing care from CHF 59/month.',
    cta: 'All prices & services',
  },
}[lang];
---

<section class="bg-offwhite text-ink">
  <div class="container-x py-20 md:py-28">
    <div class="grid gap-12 lg:grid-cols-[1fr_1fr] lg:items-center lg:gap-16">
      <div>
        <span class="font-mono text-xs font-medium tracking-wider text-gold-ink">
          <span aria-hidden="true">// </span>{copy.eyebrow}
        </span>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-ink md:text-4xl">
          {copy.heading}
        </h2>
        <p class="mt-5 max-w-md text-lg leading-relaxed text-muted">
          {copy.intro}
        </p>
        <Button href={leistungenHref} label={copy.cta} variant="solid" class="mt-8">
          <span aria-hidden="true">→</span>
        </Button>
      </div>

      <div class="grid gap-3 sm:grid-cols-3">
        {
          packages.map((pkg) => (
            <div
              class={`flex flex-col rounded-xl border p-5 ${
                pkg.featured
                  ? 'border-gold bg-white shadow-[0_10px_40px_-15px_rgba(184,153,104,0.5)]'
                  : 'border-line bg-white'
              }`}
            >
              <span class="font-display text-sm font-bold text-ink">{pkg.name}</span>
              <span class="mt-1 text-xs text-muted">{pkg.tagline}</span>
              <div class="mt-4 flex items-baseline gap-1">
                <span class="font-mono text-xs text-gold-ink">CHF</span>
                <span class="font-display text-2xl font-extrabold tracking-tight text-ink">
                  {pkg.price}
                </span>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
