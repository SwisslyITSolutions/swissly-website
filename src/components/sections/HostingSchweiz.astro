---
import Eyebrow from '../ui/Eyebrow.astro';

const points = [
  {
    title: 'Daten bleiben in der Schweiz',
    text: 'Hosting auf Schweizer Premium-Servern. Ihre Daten und die Ihrer Kunden verlassen das Land nicht — DSG-konform von Grund auf.',
  },
  {
    title: 'Eigentum bei Ihnen',
    text: 'Code, Domain und Dateien gehören Ihnen. Kein Lock-in, keine versteckten Abhängigkeiten, jederzeit volle Kontrolle.',
  },
  {
    title: 'Persönlich erreichbar',
    text: 'Ein kleines Team aus der Zentralschweiz — kein Callcenter, keine Warteschleife. Sie sprechen direkt mit den Menschen, die Ihre IT betreuen.',
  },
];
---

<section class="relative overflow-hidden bg-navy-800">
  <div
    class="pointer-events-none absolute inset-y-0 right-0 w-1/2 bg-gold/5 blur-[120px]"
    aria-hidden="true"
  >
  </div>
  <div class="container-x relative py-20 md:py-28">
    <div class="grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:gap-16">
      <div>
        <Eyebrow>swiss made</Eyebrow>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
          Hosting in der Schweiz.<br />Vertrauen inklusive.
        </h2>
        <p class="mt-5 max-w-md text-lg leading-relaxed text-white/70">
          Schweizer Engineering bedeutet für uns mehr als ein Flaggen-Emoji: kurze Wege,
          klare Verantwortung und Technik, die hält, was sie verspricht.
        </p>
        <div
          class="mt-8 inline-flex items-center gap-3 rounded-lg border border-gold/30 bg-gold/10 px-4 py-3 font-mono text-sm text-gold-bright"
        >
          <span aria-hidden="true" class="text-lg">🇨🇭</span>
          Hosted &amp; supported in Switzerland
        </div>
      </div>

      <ul class="grid gap-5 sm:grid-cols-1">
        {
          points.map((point) => (
            <li class="flex gap-4 rounded-xl border border-white/10 bg-navy-900/60 p-5">
              <span
                aria-hidden="true"
                class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border border-gold/30 bg-gold/10 font-mono text-gold-bright"
              >
                ✓
              </span>
              <div>
                <h3 class="font-display text-base font-bold text-white">{point.title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed text-white/70">{point.text}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
