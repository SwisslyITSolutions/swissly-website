---
import MobileMenu from './MobileMenu.astro';
import Button from '../ui/Button.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLang, localizedPath, type Lang } from '../../i18n/utils';
import { t } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = getLang(Astro) } = Astro.props;

const nav = [
  { label: t(lang, 'nav.leistungen'), href: localizedPath(lang, '/leistungen/') },
  { label: t(lang, 'nav.ueberUns'), href: localizedPath(lang, '/ueber-uns/') },
  { label: t(lang, 'nav.faq'), href: localizedPath(lang, '/faq/') },
  { label: t(lang, 'nav.kontakt'), href: localizedPath(lang, '/kontakt/') },
];
const ctaLabel = t(lang, 'cta.label');
const ctaHref = localizedPath(lang, '/erstgespraech/');
const homeHref = lang === 'en' ? '/en/' : '/';
---

<header
  id="site-header"
  class="sticky top-0 z-50 transition-colors duration-300"
  data-header
>
  <div class="container-x flex h-16 items-center justify-between md:h-20">
    <a href={homeHref} class="flex items-center gap-2.5" aria-label={t(lang, 'logo.ariaHome')}>
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-white p-1 shadow-sm ring-1 ring-black/5">
        <img
          src="/images/logo/swisslyit-logo.png"
          alt="Swissly IT Solutions"
          width="40"
          height="40"
          class="h-full w-full object-contain"
        />
      </span>
      <span class="font-display text-base font-extrabold tracking-wide text-white">
        SWISSLY<span class="text-gold-bright"> IT</span>
      </span>
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label={t(lang, 'nav.aria.main')}>
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="group relative font-mono text-sm text-white/80 transition hover:text-white"
          >
            {item.label}
            <span class="absolute -bottom-1 left-0 h-px w-0 bg-gold-bright transition-all duration-200 group-hover:w-full" />
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-5 lg:flex">
      <LanguageSwitcher lang={lang} />
      <Button href={ctaHref} label={ctaLabel} variant="primary" class="!px-4 !py-2.5 !text-xs" />
    </div>

    <MobileMenu nav={nav} ctaLabel={ctaLabel} ctaHref={ctaHref} lang={lang} />
  </div>
</header>

<script>
  const header = document.querySelector('[data-header]');
  if (header) {
    const solid = ['bg-navy-900/90', 'backdrop-blur', 'border-b', 'border-white/10', 'shadow-lg', 'shadow-black/20'];
    const update = () => {
      if (window.scrollY > 12) header.classList.add(...solid);
      else header.classList.remove(...solid);
    };
    update();
    window.addEventListener('scroll', update, { passive: true });
  }
</script>
