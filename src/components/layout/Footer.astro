---
import { site } from '../../data/site';
import StatusBar from './StatusBar.astro';
import { getLang, type Lang } from '../../i18n/utils';
import { t } from '../../i18n/ui';
import { getContent } from '../../i18n/content';

interface Props {
  lang?: Lang;
}
const { lang = getLang(Astro) } = Astro.props;
const c = getContent(lang);

const year = 2026;

const navLinks =
  lang === 'en'
    ? [
        { label: 'About', href: '/en/ueber-uns/' },
        { label: 'All services', href: '/en/leistungen/' },
        { label: 'Training', href: '/en/leistungen/schulungen/' },
        { label: 'FAQ', href: '/en/faq/' },
        { label: 'Contact', href: '/en/kontakt/' },
      ]
    : [
        { label: 'Über uns', href: '/ueber-uns/' },
        { label: 'Alle Leistungen', href: '/leistungen/' },
        { label: 'Schulungen', href: '/leistungen/schulungen/' },
        { label: 'FAQ', href: '/faq/' },
        { label: 'Kontakt', href: '/kontakt/' },
      ];

// Legal pages are German-only; the EN footer labels them as such and links to the DE pages.
const legalLinks =
  lang === 'en'
    ? [
        { label: 'Imprint (German)', href: '/impressum/' },
        { label: 'Privacy (German)', href: '/datenschutzerklaerung/' },
        { label: 'Terms (German)', href: '/agb/' },
      ]
    : [
        { label: 'Impressum', href: '/impressum/' },
        { label: 'Datenschutzerklärung', href: '/datenschutzerklaerung/' },
        { label: 'AGB', href: '/agb/' },
      ];
---

<footer class="border-t border-white/10 bg-navy-900 text-white/70">
  <div class="container-x py-16 md:py-20">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-12">
      <!-- Brand -->
      <div class="lg:col-span-5">
        <div class="flex items-center gap-3">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-lg bg-white p-1.5 shadow-sm ring-1 ring-black/5">
            <img
              src="/images/logo/swisslyit-logo.png"
              alt="Swissly IT Solutions"
              width="44"
              height="44"
              class="h-full w-full object-contain"
            />
          </span>
          <span class="font-display text-lg font-extrabold tracking-wide text-white">
            Swissly<span class="text-gold-bright"> IT Solutions</span>
          </span>
        </div>
        <p class="mt-4 max-w-xs font-mono text-sm text-gold-bright">{site.tagline}</p>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/60">{c.claim}</p>
        <div class="mt-6">
          <StatusBar />
        </div>
      </div>

      <!-- Navigation -->
      <nav class="lg:col-span-3" aria-label="Footer-Navigation">
        <h2 class="font-mono text-xs uppercase tracking-wider text-white/40">{t(lang, 'footer.navHeading')}</h2>
        <ul class="mt-4 flex flex-col gap-2.5 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="transition hover:text-gold-bright">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Kontakt / NAP -->
      <div class="lg:col-span-4">
        <h2 class="font-mono text-xs uppercase tracking-wider text-white/40">{t(lang, 'footer.contactHeading')}</h2>
        <address class="mt-4 flex flex-col gap-2.5 text-sm not-italic leading-relaxed">
          <span>{site.legalName}</span>
          <span>{site.address.zip} {site.address.city}, {site.address.region}</span>
          <a href={`mailto:${site.email}`} class="text-gold-bright transition hover:text-gold">
            {site.email}
          </a>
          <span class="text-white/50">{lang === 'en' ? 'Mon–Fri 09:00–17:00' : site.hours}</span>
        </address>
      </div>
    </div>

    <!-- Legal row -->
    <div
      class="mt-14 flex flex-col gap-4 border-t border-white/10 pt-8 text-sm md:flex-row md:items-center md:justify-between"
    >
      <ul class="flex flex-wrap items-center gap-x-6 gap-y-2">
        {
          legalLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/60 transition hover:text-gold-bright">
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <button
            id="cookie-settings"
            type="button"
            class="text-white/60 transition hover:text-gold-bright"
          >
            {t(lang, 'footer.cookieSettings')}
          </button>
        </li>
      </ul>
      <p class="text-xs text-white/40">
        © {year} {site.name}. {t(lang, 'footer.rights')}
      </p>
    </div>
  </div>
</footer>

<script>
  document.getElementById('cookie-settings')?.addEventListener('click', () => {
    window.swisslyConsent?.open();
  });
</script>
