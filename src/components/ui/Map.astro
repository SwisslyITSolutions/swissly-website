---
/**
 * Map.astro — OpenStreetMap / Leaflet embed.
 *
 * Leaflet JS + CSS are served from /vendor/leaflet/ (vendored, no CDN).
 * Tile images come from tile.openstreetmap.org (documented in DSV).
 * Lazy-initialised via IntersectionObserver so it only loads when visible.
 *
 * The container id is unique per instance so multiple <Map> components on the
 * same page never collide; the init script (define:vars) is scoped to it.
 */

interface Props {
  lat: number;
  lng: number;
  label: string;
  height?: string;
}

const { lat, lng, label, height = '18rem' } = Astro.props;
const mapId = `swissly-map-${Math.random().toString(36).slice(2, 9)}`;
---

<link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />

<div
  id={mapId}
  data-lat={lat}
  data-lng={lng}
  data-label={label}
  aria-label={`Karte: ${label}`}
  role="application"
  style={`height:${height};`}
  class="w-full overflow-hidden rounded-xl border border-line/20"
>
  <!-- Placeholder shown before Leaflet loads -->
  <div class="flex h-full items-center justify-center bg-navy-800 text-sm text-white/40">
    Karte wird geladen …
  </div>
</div>

<script is:inline define:vars={{ mapId }}>
  (function () {
    var el = document.getElementById(mapId);
    if (!el) return;

    // Load leaflet.js once per page, then run the callback. Subsequent maps
    // reuse window.L (or wait for the in-flight load to finish).
    function withLeaflet(cb) {
      if (window.L) {
        cb(window.L);
        return;
      }
      var existing = document.getElementById('leaflet-vendor-js');
      if (existing) {
        existing.addEventListener('load', function () {
          cb(window.L);
        });
        return;
      }
      var script = document.createElement('script');
      script.id = 'leaflet-vendor-js';
      script.src = '/vendor/leaflet/leaflet.js';
      script.addEventListener('load', function () {
        cb(window.L);
      });
      document.head.appendChild(script);
    }

    function mountMap(container) {
      var lat = parseFloat(container.dataset.lat || '0');
      var lng = parseFloat(container.dataset.lng || '0');
      var label = container.dataset.label || '';

      withLeaflet(function (L) {
        container.innerHTML = '';

        var map = L.map(container, { scrollWheelZoom: false }).setView([lat, lng], 16);

        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution:
            '&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener">OpenStreetMap</a>',
          maxZoom: 19,
        }).addTo(map);

        var icon = L.icon({
          iconUrl: '/vendor/leaflet/images/marker-icon.png',
          iconRetinaUrl: '/vendor/leaflet/images/marker-icon-2x.png',
          shadowUrl: '/vendor/leaflet/images/marker-shadow.png',
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
          shadowSize: [41, 41],
        });

        L.marker([lat, lng], { icon }).addTo(map).bindPopup(label).openPopup();
      });
    }

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(
        function (entries) {
          for (var i = 0; i < entries.length; i++) {
            if (entries[i].isIntersecting) {
              observer.disconnect();
              mountMap(el);
            }
          }
        },
        { threshold: 0.1 },
      );
      observer.observe(el);
    } else {
      mountMap(el);
    }
  })();
</script>
