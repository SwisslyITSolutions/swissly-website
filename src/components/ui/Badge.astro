---
interface Props {
  tone?: 'gold' | 'neutral';
  class?: string;
}

const { tone = 'gold', class: className = '' } = Astro.props;

const tones: Record<NonNullable<Props['tone']>, string> = {
  gold: 'border-gold/40 bg-gold/15 text-gold-bright',
  neutral: 'border-white/15 bg-white/10 text-white/80',
};
---

<span
  class={`inline-flex items-center rounded-full border px-3 py-1 font-mono text-xs ${tones[tone]} ${className}`}
>
  <slot />
</span>
